client
dev tun
proto tcp-client
remote 161.118.177.7 53
resolv-retry infinite
nobind
persist-key
persist-tun
remote-cert-tls server

# Speed optimizations
tun-mtu 1200
mssfix 1200
compress lz4-v2
fast-io

# Buffers
sndbuf 65536
rcvbuf 65536

# Reconnection
reconnect 3
ping 3
ping-restart 10

verb 3
redirect-gateway def1 bypass-dhcp

